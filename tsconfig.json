{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "lib": ["ESNext"],
    "types": ["node"],
    
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "erasableSyntaxOnly": true,
    "moduleDetection": "force",

    "noEmit": true,
    
    "strict": true,
    // "noUncheckedIndexedAccess": true
  },
  "include": ["scripts"]
}
